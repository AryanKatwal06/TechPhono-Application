# TechPhono - final React Native CLI ignore list

# Dependencies
node_modules/

# Environment and local config
.env
.env.*
!.env.example
config/publicConfig.local.ts
.firebaserc

# React Native / Metro / cache
.metro-cache/
.metro-health-check*
.parcel-cache/
.expo/
.cache/
.tmp/
.temp/
tmp/
temp/
*.tsbuildinfo
*.jsbundle
*.hbc

# Logs and reports
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.nyc_output/
reports/

# Android
android/.gradle/
android/.cxx/
android/build/
android/app/build/
android/local.properties
android/*/local.properties
android/app/google-services.json
*.apk
*.aab
*.jks
*.keystore
*.keystore.*

# iOS
ios/build/
ios/Pods/
Pods/
DerivedData/
*.xcworkspace
**/GoogleService-Info.plist

# Firebase / backend
.firebase/
firebase-debug.log
firestore-debug.log
functions/lib/
functions/**/*.tsbuildinfo
service-account*.json
*-credentials.json

# Secrets and key material
*.key
*.pem
*.p8
*.p12
*.mobileprovision
*.secret
*.enc

# IDEs and editors
.vscode/
.idea/
*.iml
*.sublime-workspace
*.sublime-project
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Repo-local cleanup helpers
check.js
cleaned-check/
repo-mirror/

# Package manager extras
.pnp.cjs
.pnp.js
.store/

# Gradle
.gradle/
.gradle