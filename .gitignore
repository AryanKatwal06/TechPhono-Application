# -----------------------------
# TechPhono - .gitignore (React Native CLI)
# Generated/compiled files, secrets, IDE and OS files to keep out of Git
# -----------------------------

# Node modules
node_modules/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Environment files (do NOT commit secrets)
# allows an example template while ignoring real env files
.env
.env.*
!.env.example

# React Native / Metro
.parcel-cache/
.metro-cache/
.metro-health-check*
*.jsbundle
*.hbc

# Build artifacts
build/
dist/
out/
coverage/
*.tsbuildinfo
*.apk
*.aab

# Android
android/.gradle/
android/app/build/
android/build/
android/local.properties
android/*/local.properties
android/app/google-services.json

# iOS
ios/build/
ios/Pods/
Pods/
DerivedData/
*.xcworkspace
# Ignore any Google plist containing Firebase config
**/GoogleService-Info.plist

# Keystores and signing
*.jks
*.keystore
*.keystore.*

# Firebase / Google Cloud
.firebase/
firebase-debug.log
functions/lib/
functions/**/*.tsbuildinfo
service-account*.json
*-credentials.json

# Keys / secrets
*.key
*.pem
*.p8
*.p12
*.mobileprovision
*.enc
*.secret

# IDEs and editors
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Temp and caches
.cache/
.local/
.temp/
.tmp/
tmp/
*.tmp
*.temp

# CI / Coverage / Reports
.nyc_output/
.expo/
reports/

# Dependency directories (optional package managers)
.pnp.cjs
.pnp.js
.store/

# Generated by AI / large artifacts
# (some tools create transient files; keep these out of repo)
*.generated.js
*.ai.json

# Misc
.gradle/
.gradle

