# TechPhono - comprehensive React Native / Expo .gitignore

# Node
node_modules/

# Environment and local config
.env
.env.*
!.env.example
config/publicConfig.local.ts
.firebaserc

# Expo / React Native caches and build artifacts
.expo/
.expo-shared/
.expo/packager-cache-*
.expo/web/
.cache/
.parcel-cache/
.metro-cache/
.metro-health-check*
.tmp/
tmp/
*.tsbuildinfo
*.jsbundle
*.hbc

# Metro/Expo autolinking noisy build folders (Windows watcher fixes)
node_modules/expo-modules-autolinking/**/build/**

# Logs and coverage
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.nyc_output/
reports/
coverage/

# Android
android/.gradle/
android/.cxx/
android/build/
android/app/build/
android/local.properties
android/*/local.properties
android/app/src/main/assets/index.android.bundle
android/keystore.properties
keystore.properties
*.apk
*.aab
*.jks
*.keystore

# iOS
ios/build/
ios/Pods/
Pods/
DerivedData/
*.xcworkspace
*.xcuserstate
*.xcarchive
*.ipa
*.dSYM

# Firebase / backend
.firebase/
firebase-debug.log
firestore-debug.log
functions/lib/
service-account*.json
*-credentials.json

# Secrets and key material
*.key
*.pem
*.p8
*.p12
*.mobileprovision
*.secret
*.enc

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots

# IDEs and editors
.vscode/
.idea/
*.iml
*.sublime-workspace
*.sublime-project
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Misc build / temp
.gradle/
build/
dist/
uploads/
*.bak
*.orig
*.tmp

# Repo-local helpers
check.js
cleaned-check/
repo-mirror/